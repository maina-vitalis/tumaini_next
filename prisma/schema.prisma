generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tour {
  id          String   @id @default(uuid())
  tourName    String
  price       Float
  booking     Float
  images      Json     @default("[]") // Array of image URLs
  rating      Int
  difficulty  String
  level       String
  hikeType    String
  location    String
  date        String
  description String
  summary     String
  itinerary   Json     @default("[]") // Array of {time: string, details: string}
  inclusive   Json     @default("[]")
  exclusive   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([location])
  @@index([createdAt])
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
